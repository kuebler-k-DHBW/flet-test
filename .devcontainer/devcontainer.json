{
  "name": "Flet Python Codespace",
  "image": "mcr.microsoft.com/devcontainers/python:3.11",
  "postCreateCommand": "pip install -r requirements.txt",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance"
      ]
    }
  },
  "forwardPorts": [8550],
  "portsAttributes": {
    "8550": {
      "label": "Flet App",
      "onAutoForward": "openBrowser"
    }
  }
}
